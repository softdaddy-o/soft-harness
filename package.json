{
  "name": "soft-harness",
  "version": "0.4.33",
  "description": "Shared plugin core with Claude Code and Codex wrappers for analyzing and organizing live host configs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/softdaddy-o/soft-harness.git"
  },
  "bugs": {
    "url": "https://github.com/softdaddy-o/soft-harness/issues"
  },
  "homepage": "https://github.com/softdaddy-o/soft-harness#readme",
  "bin": {
    "soft-harness": "src/cli.js"
  },
  "files": [
    ".agents",
    ".claude-plugin",
    "plugins",
    "scripts",
    "src",
    "docs",
    "examples",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/cli.js",
    "eval:llm": "node scripts/run-llm-eval.js list",
    "eval:llm:codex": "node scripts/run-llm-eval.js codex analyze-clean-start-dry-run",
    "eval:skills": "node scripts/run-skill-evals.js",
    "version": "node scripts/sync-version.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "keywords": [
    "claude",
    "codex",
    "mcp",
    "agents",
    "skills",
    "plugins",
    "harness",
    "analyze",
    "organize",
    "plugin"
  ],
  "author": "softdaddy-o",
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
